# ==========================================
# TYLA NOVA TECH
# Next-Generation WhatsApp Multi-Device Bot
# ==========================================

# ==========================
# BOT INFORMATION
# ==========================
BOT_NAME=TYLA NOVA TECH
BOT_VERSION=1.0.0
BOT_PREFIX=.
BOT_MODE=public

# ==========================
# OWNER
# ==========================
OWNER_NAME=Tyla
OWNER_NUMBER=234XXXXXXXXXX
OWNER_ID=234XXXXXXXXXX@s.whatsapp.net

# ==========================
# WHATSAPP
# ==========================
WHATSAPP_SESSION_NAME=TYLA-NOVA
WHATSAPP_OWNER_NUMBER=
WHATSAPP_BOT_NAME=TYLA NOVA MD
WHATSAPP_BOT_PREFIX=.
WHATSAPP_AUTO_READ=true
WHATSAPP_AUTO_TYPING=false

# ==========================
# TELEGRAM CONTROL PANEL
# ==========================
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_ID=
TELEGRAM_WEBHOOK_URL=

# ==========================
# AI API
# ==========================
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# ==========================
# DATABASE
# ==========================
DB_TYPE=sqlite
DB_PATH=./database/tyla.db

# ==========================
# SECURITY
# ==========================
RATE_LIMIT=true
MAX_WARNINGS=3
ANTI_LINK=true
ANTI_SPAM=true
ANTI_BOT=false
ANTI_DELETE=false

# ==========================
# DOWNLOAD
# ==========================
MAX_DOWNLOAD_SIZE=100

# ==========================
# LOGGING
# ==========================
LOG_LEVEL=info
LOG_FILE=./logs/bot.log

# ==========================
# DEPLOYMENT
# ==========================
PORT=3000
NODE_ENV=production
TIMEZONE=Africa/Lagos